<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Poxiao" parent="Theme.AppCompat.DayNight.NoActionBar" />

    <!-- 闪屏主题 -->
    <style name="Theme.Poxiao.Splash" parent="Theme.SplashScreen">
        <!-- 闪屏背景色，配合暗色/黑色图标设定为纯黑 -->
        <item name="windowSplashScreenBackground">#000000</item>
        <!-- 重新挂载应用图标作为闪屏动画的中心图标 -->
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_round</item>
        <!-- 启动后的主题 -->
        <item name="postSplashScreenTheme">@style/Theme.Poxiao</item>
    </style>
</resources>
